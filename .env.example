# Triageo environment variables
# Copy this file to .env and fill in values before running.

# Host IP to bind ports to (home server LAN address)
HOST_IP=0.0.0.0

# API service
API_PORT=8004

# Web service
WEB_PORT=3004

# LLM provider — "openai" or "anthropic"
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic (alternative provider)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-haiku-20240307

# Google Gemini (alternative provider)
# Get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# App settings
LOG_LEVEL=info
